---
import { Reveal } from './SitePrimitives';
import OptimizedImage from './OptimizedImage.astro';
import type { SocialGroup, StudioData } from './types';

interface Props {
  studio: StudioData;
  socialGroups: SocialGroup[];
}

const { studio, socialGroups } = Astro.props;
const groupedLinks = socialGroups.map((group) => ({
  title: group.title,
  links: group.links
}));
---

<Reveal delay={120}>
  <footer class="container mx-auto mt-20 max-w-6xl px-6 pb-12 pt-10">
    <div class="grid gap-10 border-t border-white/8 pt-8 lg:grid-cols-[minmax(0,1fr)_minmax(0,1.2fr)] lg:items-start">
      <div class="space-y-5">
        <div class="flex items-center gap-4">
        <OptimizedImage
          src={studio.logo}
          alt={`${studio.title} logo`}
          loading="lazy"
          decoding="async"
          widths={[56, 96]}
          sizes="56px"
          class="h-14 w-14 rounded-xl object-contain"
        />
          <div>
            <p class="text-2xl font-black tracking-tight text-white">FenroarGames</p>
            <p class="mt-1 text-sm font-semibold uppercase tracking-[0.22em] text-white/42">{studio.tagline}</p>
          </div>
        </div>
        <p class="max-w-md text-base leading-7 text-white/62">
          System-driven games, public iteration, and strategy that reads fast but plays deep.
        </p>
      </div>

      <div class="grid gap-8 sm:grid-cols-2">
        {groupedLinks.map((group) => (
          <div class="space-y-4">
            <p class="text-[0.72rem] font-black uppercase tracking-[0.28em] text-cyan-300">{group.title}</p>
            <div class="grid gap-3">
              {group.links.map((link) => (
                <a
                  href={link.href}
                  target="_blank"
                  rel="noreferrer"
                  class="inline-flex items-center justify-between border-b border-white/8 pb-3 text-sm font-bold uppercase tracking-[0.16em] text-white/74 transition duration-300 hover:border-[#d4af37]/40 hover:text-[#d4af37]"
                >
                  <span>{link.label}</span>
                  <span class="text-white/32">Open</span>
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </footer>
</Reveal>
