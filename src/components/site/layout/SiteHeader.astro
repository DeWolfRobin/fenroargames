---
import OptimizedImage from '../shared/OptimizedImage.astro';
import { navItems } from '../shared/constants';
import type { StudioData } from '../shared/types';

interface Props {
  studio: StudioData;
}

const { studio } = Astro.props;
---

<header class="sticky top-0 z-40 border-b border-white/8 bg-[#0b0b0f]/78 backdrop-blur-xl">
  <div class="container mx-auto max-w-6xl px-4 py-3 sm:px-6 sm:py-4">
    <div class="space-y-3 lg:hidden">
      <div class="flex items-center justify-between gap-3">
        <a href="#top" class="inline-flex min-w-0 items-center gap-3 no-underline">
          <OptimizedImage
            src={studio.logo}
            alt={`${studio.title} logo`}
            loading="eager"
            decoding="async"
            fetchpriority="high"
            widths={[64, 96, 128]}
            sizes="44px"
            class="h-11 w-11 rounded-xl object-contain"
          />
          <span class="min-w-0 grid leading-none">
            <span class="truncate text-[0.82rem] font-black uppercase tracking-[0.22em] text-white">Fenroar Games</span>
            <span class="mt-1 truncate text-[0.62rem] font-semibold uppercase tracking-[0.16em] text-white/42">{studio.tagline}</span>
          </span>
        </a>

        <a
          href="https://discord.gg/vPKjWEBFBq"
          target="_blank"
          rel="noreferrer"
          class="inline-flex min-h-10 shrink-0 items-center justify-center rounded-full border border-[#d4af37]/30 bg-[#d4af37] px-4 text-[0.72rem] font-black uppercase tracking-[0.12em] text-black transition duration-300 hover:bg-[#e3c15b]"
        >
          Discord
        </a>
      </div>

      <nav class="-mx-1 flex gap-2 overflow-x-auto px-1 pb-1 text-[0.65rem] font-black uppercase tracking-[0.16em] text-white/70 [scrollbar-width:none] [&::-webkit-scrollbar]:hidden">
        {navItems.map((item) => (
          <a
            href={item.href}
            class="inline-flex shrink-0 items-center rounded-full border border-white/10 bg-white/[0.04] px-3 py-2 transition duration-300 hover:border-[#d4af37]/35 hover:text-[#d4af37]"
          >
            {item.label}
          </a>
        ))}
      </nav>
    </div>

    <div class="hidden lg:flex lg:flex-row lg:items-center lg:justify-between">
      <a href="#top" class="inline-flex items-center gap-3 no-underline">
        <OptimizedImage
          src={studio.logo}
          alt={`${studio.title} logo`}
          loading="eager"
          decoding="async"
          fetchpriority="high"
          widths={[64, 96, 128]}
          sizes="48px"
          class="h-12 w-12 rounded-xl object-contain"
        />
        <span class="grid leading-none">
          <span class="text-sm font-black uppercase tracking-[0.32em] text-white">Fenroar Games</span>
          <span class="mt-1 text-[0.68rem] font-semibold uppercase tracking-[0.22em] text-white/42">{studio.tagline}</span>
        </span>
      </a>

      <nav class="flex flex-wrap gap-x-5 gap-y-2 text-xs font-black uppercase tracking-[0.26em] text-white/58">
        {navItems.map((item) => (
          <a href={item.href} class="transition duration-300 hover:text-[#d4af37]">
            {item.label}
          </a>
        ))}
      </nav>

      <a
        href="https://discord.gg/vPKjWEBFBq"
        target="_blank"
        rel="noreferrer"
        class="inline-flex min-h-11 items-center justify-center rounded-full border border-[#d4af37]/30 bg-[#d4af37] px-5 text-sm font-black uppercase tracking-[0.18em] text-black transition duration-300 hover:scale-[1.03] hover:bg-[#e3c15b]"
      >
        Join Discord
      </a>
    </div>
  </div>
</header>
