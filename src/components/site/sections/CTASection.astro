---
import ButtonLink from '../shared/ButtonLink.astro';
import Reveal from '../shared/Reveal.astro';
import Surface from '../shared/Surface.astro';
import { sectionContainerClass } from '../shared/classes';

interface Props {
  playLink: string;
  discordLink: string;
}

const { playLink, discordLink } = Astro.props;
---

<section class={sectionContainerClass}>
  <Reveal>
    <Surface
      tone="dark"
      class="overflow-hidden border-[#d4af37]/18 bg-[radial-gradient(circle_at_top_left,rgba(212,175,55,0.18),transparent_28%),radial-gradient(circle_at_bottom_right,rgba(72,196,255,0.16),transparent_35%),linear-gradient(180deg,#0b0b0f,#12131a)] p-8 sm:p-10"
    >
      <h2 class="max-w-4xl text-5xl font-black tracking-tight text-white sm:text-6xl lg:text-7xl">
        Step into the alpha.
        <br />
        Stay for the next reveal.
      </h2>
      <div class="mt-8 flex flex-wrap gap-3">
        <ButtonLink href={playLink}>Play / Download</ButtonLink>
        <ButtonLink href={discordLink} variant="secondary">Join Discord</ButtonLink>
      </div>
    </Surface>
  </Reveal>
</section>
