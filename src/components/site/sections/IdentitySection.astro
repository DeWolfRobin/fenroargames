---
import Reveal from '../shared/Reveal.astro';
import { sectionContainerClass } from '../shared/classes';

interface Props {
  statements: string[];
}

const { statements } = Astro.props;
---

<section id="identity" class={sectionContainerClass}>
  <Reveal>
    <div class="space-y-5">
      <p class="text-xs font-black uppercase tracking-[0.32em] text-cyan-300">Studio Identity</p>
      <div class="grid gap-4">
        {statements.map((statement, index) => (
          <div
            class:list={[
              'rounded-[1.6rem] border px-4 py-5 text-white sm:px-8 sm:py-7',
              index === 1 ? 'border-cyan-300/25 bg-cyan-300/[0.06]' : 'border-white/10 bg-white/[0.04] text-white/92'
            ]}
          >
            <p class="text-3xl font-black tracking-tight sm:text-5xl lg:text-6xl">{statement}</p>
          </div>
        ))}
      </div>
    </div>
  </Reveal>
</section>
