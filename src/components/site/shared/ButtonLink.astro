---
interface Props {
  href: string;
  variant?: 'primary' | 'secondary';
  target?: '_blank' | '_self';
  rel?: string;
  class?: string;
}

const { href, variant = 'primary', target, rel, class: className = '' } = Astro.props;

const variantClass =
  variant === 'primary'
    ? 'border-transparent bg-[#d4af37] text-black shadow-[0_18px_50px_rgba(212,175,55,0.24)] hover:-translate-y-0.5 hover:bg-[#e3c15b]'
    : 'border-white/14 bg-white/[0.08] text-white hover:-translate-y-0.5 hover:border-cyan-300/35 hover:bg-white/[0.12]';
---

<a
  href={href}
  target={target}
  rel={rel}
  class:list={[
    'inline-flex min-h-12 items-center justify-center rounded-full border px-6 text-base font-bold transition',
    variantClass,
    className
  ]}
>
  <slot />
</a>
