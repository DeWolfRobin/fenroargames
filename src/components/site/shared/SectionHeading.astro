---
interface Props {
  eyebrow: string;
  title: string;
  text?: string;
  invert?: boolean;
}

const { eyebrow, title, text, invert = false } = Astro.props;
---

<div class="max-w-3xl space-y-3">
  <p class:list={['text-[0.72rem] font-black uppercase tracking-[0.32em]', invert ? 'text-cyan-300' : 'text-[#d4af37]']}>
    {eyebrow}
  </p>
  <h2 class="text-4xl font-black tracking-tight text-white sm:text-5xl lg:text-6xl">{title}</h2>
  {text ? <p class="max-w-2xl text-base leading-7 text-zinc-300">{text}</p> : null}
</div>
