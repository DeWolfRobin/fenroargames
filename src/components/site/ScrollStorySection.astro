---
import { Button, Pill, Reveal, SectionHeading, Surface } from './SitePrimitives';
import OptimizedImage from './OptimizedImage.astro';
import type { Screenshot } from './types';

type StoryCard = {
  eyebrow: string;
  title: string;
  body: string;
  accent?: string;
};

interface Props {
  id: string;
  eyebrow: string;
  title: string;
  text: string;
  screenshot: Screenshot;
  mediaEyebrow: string;
  mediaTitle: string;
  mediaText: string;
  cards: StoryCard[];
  cta?: { label: string; href: string };
}

const { id, eyebrow, title, text, screenshot, mediaEyebrow, mediaTitle, mediaText, cards, cta } = Astro.props;
---

<section id={id} className="section-chunk scroll-mt-28 py-8 lg:py-14">
  <div className="grid gap-8 lg:grid-cols-[minmax(0,0.95fr)_minmax(0,1.05fr)] lg:items-start">
    <div className="lg:sticky lg:top-28">
      <Reveal>
        <SectionHeading eyebrow={eyebrow} title={title} text={text} />
      </Reveal>

      <Reveal delay={100}>
        <Surface className="mt-6 overflow-hidden p-4 sm:p-5">
          <div className="relative overflow-hidden rounded-[1.2rem] border border-stone-200 bg-slate-950">
            <OptimizedImage
              src={screenshot.src}
              alt={screenshot.alt}
              loading="lazy"
              decoding="async"
              widths={[540, 900, 1200]}
              sizes="(min-width: 1024px) 40vw, 100vw"
              quality={82}
              class="aspect-[4/3] w-full object-cover"
            />
            <div className="absolute inset-x-4 bottom-4 rounded-[1rem] border border-white/10 bg-slate-950/80 p-5 backdrop-blur">
              <p className="text-[0.72rem] font-black uppercase tracking-[0.32em] text-cyan-300">{mediaEyebrow}</p>
              <h3 className="mt-2 text-3xl font-black tracking-tight text-white">{mediaTitle}</h3>
              <p className="mt-3 text-base leading-7 text-slate-300">{mediaText}</p>
            </div>
          </div>
        </Surface>
      </Reveal>

      {cta ? (
        <Reveal delay={180} className="mt-5">
          <Button href={cta.href}>{cta.label}</Button>
        </Reveal>
      ) : null}
    </div>

    <div className="grid gap-5">
      {cards.map((card, index) => (
        <Reveal delay={120 + index * 90}>
          <Surface className="min-h-[22rem] p-6 sm:p-8 lg:min-h-[28rem]">
            <div className="flex h-full flex-col justify-between gap-8">
              <div className="space-y-4">
                <p className={['text-[0.72rem] font-black uppercase tracking-[0.32em]', card.accent ?? 'text-[#ff6b2c]'].join(' ')}>
                  {card.eyebrow}
                </p>
                <h3 className="max-w-[14ch] text-4xl font-black tracking-tight text-slate-950 sm:text-5xl">{card.title}</h3>
                <p className="max-w-2xl text-lg leading-8 text-slate-600">{card.body}</p>
              </div>

              <div className="flex flex-wrap gap-3">
                <Pill>{String(index + 1).padStart(2, '0')}</Pill>
                <Pill>{card.eyebrow}</Pill>
              </div>
            </div>
          </Surface>
        </Reveal>
      ))}
    </div>
  </div>
</section>
