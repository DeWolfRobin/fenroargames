---
import { Button, Pill, Reveal, SectionHeading, Surface } from './SitePrimitives';
import OptimizedImage from './OptimizedImage.astro';
import type { GameData } from './types';

interface Props {
  game: GameData;
}

const { game } = Astro.props;
const stepVisuals = [game.screenshots[2], game.screenshots[3], game.screenshots[0], game.screenshots[1]];
---

<section id="featured-game" class="section-chunk container mx-auto max-w-6xl px-6 py-24">
  <div class="grid gap-10 lg:grid-cols-[minmax(0,0.95fr)_minmax(0,1.05fr)]">
    <div class="lg:sticky lg:top-28 lg:self-start">
      <Reveal>
        <SectionHeading eyebrow="Featured Game" title={game.title} text={game.subtitle} invert />
      </Reveal>

      <Reveal delay={80}>
        <Surface
          tone="dark"
          className="mt-8 overflow-hidden border-white/12 bg-[linear-gradient(180deg,rgba(255,255,255,0.06),rgba(255,255,255,0.03))] p-4"
        >
          <div class="relative overflow-hidden rounded-[1.4rem] border border-white/10 bg-[#090b10]">
            <div class="absolute inset-0 bg-[linear-gradient(135deg,rgba(212,175,55,0.16),transparent_35%),radial-gradient(circle_at_80%_20%,rgba(72,196,255,0.18),transparent_28%)]"></div>
            <OptimizedImage
              src={game.screenshots[2].src}
              alt={game.screenshots[2].alt}
              loading="eager"
              decoding="async"
              fetchpriority="high"
              widths={[640, 960, 1280]}
              sizes="(min-width: 1024px) 42vw, 100vw"
              quality={84}
              class="aspect-[4/5] w-full object-cover opacity-88"
            />
            <div class="absolute inset-x-4 top-4 flex flex-wrap gap-2">
              <Pill invert>{game.status}</Pill>
              <Pill invert>Dice-driven strategy</Pill>
            </div>
            <div class="absolute inset-x-4 bottom-4 rounded-[1rem] border border-white/12 bg-black/55 p-4 backdrop-blur">
              <p class="text-xs font-black uppercase tracking-[0.28em] text-cyan-300">Sticky Story</p>
              <p class="mt-2 text-2xl font-black tracking-tight text-white sm:text-3xl">One concept per step</p>
            </div>
          </div>
        </Surface>
      </Reveal>

      <Reveal delay={140} className="mt-6 flex flex-wrap gap-3">
        <Button href={game.playLink}>Play on itch.io</Button>
        <Button href="#projects" variant="secondary">
          See other projects
        </Button>
      </Reveal>
    </div>

    <div class="space-y-5">
      {game.featureSteps.map((step, index) => {
        const visual = stepVisuals[index];

        return (
          <Reveal delay={index * 70}>
            <div class="grid gap-4 rounded-[1.7rem] border border-white/10 bg-white/[0.04] p-4 transition-all duration-300 hover:scale-[1.01] hover:border-[#d4af37]/35 hover:shadow-[0_24px_70px_rgba(0,0,0,0.28)] sm:p-5">
              <div class="grid gap-4 md:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] md:items-center">
                <div class="relative overflow-hidden rounded-[1.2rem] border border-white/8 bg-[#0a0d12]">
                  <OptimizedImage
                    src={visual.src}
                    alt={visual.alt}
                    loading="lazy"
                    decoding="async"
                    widths={[420, 720, 960]}
                    sizes="(min-width: 768px) 22vw, 100vw"
                    quality={78}
                    class="aspect-[16/11] w-full object-cover"
                  />
                  <div class="absolute inset-x-3 bottom-3 rounded-xl border border-white/10 bg-black/55 px-3 py-2 backdrop-blur">
                    <p class="text-[0.68rem] font-black uppercase tracking-[0.24em] text-cyan-300">{step.visualTitle}</p>
                    <p class="mt-1 text-sm font-semibold text-white/80">{step.visualNote}</p>
                  </div>
                </div>

                <div class="space-y-3">
                  <p class="text-xs font-black uppercase tracking-[0.28em] text-[#d4af37]">{step.label}</p>
                  <h3 class="max-w-[12ch] text-3xl font-black tracking-tight text-white sm:text-4xl">{step.title}</h3>
                  <p class="max-w-xl text-base leading-7 text-zinc-300">{step.description}</p>
                </div>
              </div>
            </div>
          </Reveal>
        );
      })}
    </div>
  </div>
</section>
